generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Multi-Tenant ───────────────────────────────────────────────

model Tenant {
  id              String              @id @default(uuid())
  name            String
  slug            String              @unique
  domain          String?             @unique
  logoUrl         String?             @map("logo_url")
  branding        Json?
  isolationMode   TenantIsolationMode @default(SCHEMA) @map("isolation_mode")
  securityConfig  Json?               @map("security_config")
  settings        Json?
  isActive        Boolean             @default(true) @map("is_active")
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")
  users           User[]
  candidates      Candidate[]
  questions       Question[]
  topics          Topic[]
  exams           Exam[]
  auditLogs       AuditLog[]

  @@map("tenants")
}

enum TenantIsolationMode {
  SCHEMA
  DATABASE
  ROW_LEVEL
}

// ─── Authentication & Users ─────────────────────────────────────

model User {
  id              String      @id @default(uuid())
  tenantId        String      @map("tenant_id")
  email           String
  passwordHash    String      @map("password_hash")
  firstName       String      @map("first_name")
  lastName        String      @map("last_name")
  phone           String?
  avatarUrl       String?     @map("avatar_url")
  status          UserStatus  @default(PENDING_VERIFICATION)
  mfaEnabled      Boolean     @default(false) @map("mfa_enabled")
  mfaSecret       String?     @map("mfa_secret")
  emailVerified   Boolean     @default(false) @map("email_verified")
  phoneVerified   Boolean     @default(false) @map("phone_verified")
  lastLoginAt     DateTime?   @map("last_login_at")
  failedAttempts  Int         @default(0) @map("failed_attempts")
  lockedUntil     DateTime?   @map("locked_until")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")
  tenant          Tenant      @relation(fields: [tenantId], references: [id])
  userRoles       UserRole[]
  sessions        Session[]
  loginHistory    LoginHistory[]
  candidate       Candidate?
  createdQuestions Question[] @relation("QuestionCreator")
  approvedVersions QuestionVersion[] @relation("QuestionApprover")
  createdExams    Exam[]      @relation("ExamCreator")
  auditLogs       AuditLog[]
  passwordResetTokens PasswordResetToken[]

  @@unique([tenantId, email])
  @@index([tenantId, status])
  @@map("users")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING_VERIFICATION
}

model Role {
  id              String          @id @default(uuid())
  name            String          @unique
  description     String?
  isSystem        Boolean         @default(false) @map("is_system")
  createdAt       DateTime        @default(now()) @map("created_at")
  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@map("roles")
}

model Permission {
  id              String          @id @default(uuid())
  code            String          @unique
  module          String
  action          String
  description     String?

  rolePermissions RolePermission[]

  @@map("permissions")
}

model UserRole {
  id              String    @id @default(uuid())
  userId          String    @map("user_id")
  roleId          String    @map("role_id")
  assignedAt      DateTime  @default(now()) @map("assigned_at")
  assignedBy      String?   @map("assigned_by")
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role            Role      @relation(fields: [roleId], references: [id])

  @@unique([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  id              String      @id @default(uuid())
  roleId          String      @map("role_id")
  permissionId    String      @map("permission_id")
  role            Role        @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission      Permission  @relation(fields: [permissionId], references: [id])

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model Session {
  id                  String    @id @default(uuid())
  userId              String    @map("user_id")
  refreshTokenHash    String    @map("refresh_token_hash")
  deviceFingerprint   String    @map("device_fingerprint")
  userAgent           String    @map("user_agent")
  ipAddress           String    @map("ip_address")
  isTrustedDevice     Boolean   @default(false) @map("is_trusted_device")
  expiresAt           DateTime  @map("expires_at")
  revokedAt           DateTime? @map("revoked_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([refreshTokenHash])
  @@map("sessions")
}

model LoginHistory {
  id                  String    @id @default(uuid())
  userId              String    @map("user_id")
  ipAddress           String    @map("ip_address")
  userAgent           String    @map("user_agent")
  deviceFingerprint   String    @map("device_fingerprint")
  success             Boolean
  failureReason       String?   @map("failure_reason")
  geoCountry          String?   @map("geo_country")
  geoCity             String?   @map("geo_city")
  createdAt           DateTime  @default(now()) @map("created_at")
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@map("login_history")
}

// ─── Candidates ─────────────────────────────────────────────────

model Candidate {
  id                  String      @id @default(uuid())
  tenantId            String      @map("tenant_id")
  userId              String      @unique @map("user_id")
  registrationNumber  String      @map("registration_number")
  dateOfBirth         DateTime?   @map("date_of_birth")
  gender              String?
  aadhaarHash         String?     @map("aadhaar_hash")
  kycStatus           KycStatus   @default(NOT_SUBMITTED) @map("kyc_status")
  kycVerifiedAt       DateTime?   @map("kyc_verified_at")
  profileData         Json?       @map("profile_data")
  photoUrl            String?     @map("photo_url")
  faceEmbedding       String?     @map("face_embedding")
  createdAt           DateTime    @default(now()) @map("created_at")
  updatedAt           DateTime    @updatedAt @map("updated_at")
  tenant              Tenant      @relation(fields: [tenantId], references: [id])
  user                User        @relation(fields: [userId], references: [id])
  documents           CandidateDocument[]
  registrations       ExamRegistration[]
  examSessions        ExamSession[]
  results             ExamResult[]

  @@unique([tenantId, registrationNumber])
  @@index([tenantId, kycStatus])
  @@map("candidates")
}

enum KycStatus {
  NOT_SUBMITTED
  PENDING
  VERIFIED
  REJECTED
}

model CandidateDocument {
  id              String    @id @default(uuid())
  candidateId     String    @map("candidate_id")
  type            String
  fileName        String    @map("file_name")
  fileUrl         String    @map("file_url")
  fileSize        Int       @map("file_size")
  mimeType        String    @map("mime_type")
  verified        Boolean   @default(false)
  uploadedAt      DateTime  @default(now()) @map("uploaded_at")
  candidate       Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([candidateId, type])
  @@map("candidate_documents")
}

// ─── Question Bank ──────────────────────────────────────────────

model Topic {
  id              String      @id @default(uuid())
  tenantId        String      @map("tenant_id")
  name            String
  parentId        String?     @map("parent_id")
  description     String?
  createdAt       DateTime    @default(now()) @map("created_at")
  tenant          Tenant      @relation(fields: [tenantId], references: [id])
  parent          Topic?      @relation("TopicHierarchy", fields: [parentId], references: [id])
  children        Topic[]     @relation("TopicHierarchy")
  questions       Question[]

  @@unique([tenantId, name, parentId])
  @@map("topics")
}

model Question {
  id                  String            @id @default(uuid())
  tenantId            String            @map("tenant_id")
  type                QuestionType
  difficulty          QuestionDifficulty @default(MEDIUM)
  topicId             String?           @map("topic_id")
  title               String?
  description         String?
  currentVersionId    String?           @map("current_version_id")
  status              QuestionStatus    @default(DRAFT)
  createdById         String            @map("created_by_id")
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")
  tenant              Tenant            @relation(fields: [tenantId], references: [id])
  topic               Topic?            @relation(fields: [topicId], references: [id])
  createdBy           User              @relation("QuestionCreator", fields: [createdById], references: [id])
  versions            QuestionVersion[]
  tags                QuestionTag[]
  examQuestions       ExamQuestion[]
  responses           SessionResponse[]

  @@index([tenantId, type, status])
  @@index([tenantId, difficulty])
  @@map("questions")
}

enum QuestionType {
  MCQ
  MSQ
  NUMERICAL
  SUBJECTIVE
  CODING
  CASE_STUDY
  AUDIO
  VIDEO
}

enum QuestionDifficulty {
  EASY
  MEDIUM
  HARD
  EXPERT
}

enum QuestionStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
  ARCHIVED
}

model QuestionVersion {
  id              String    @id @default(uuid())
  questionId      String    @map("question_id")
  versionNumber   Int       @map("version_number")
  content         Json
  options         Json?
  correctAnswer   Json?     @map("correct_answer")
  mediaRefs       Json?     @map("media_refs")
  marks           Float     @default(1)
  negativeMarks   Float     @default(0) @map("negative_marks")
  explanation     String?
  testCases       Json?     @map("test_cases")
  approvedById    String?   @map("approved_by_id")
  approvedAt      DateTime? @map("approved_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  question        Question  @relation(fields: [questionId], references: [id], onDelete: Cascade)
  approvedBy      User?     @relation("QuestionApprover", fields: [approvedById], references: [id])

  @@unique([questionId, versionNumber])
  @@map("question_versions")
}

model QuestionTag {
  id              String    @id @default(uuid())
  questionId      String    @map("question_id")
  tag             String

  question        Question  @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([questionId, tag])
  @@index([tag])
  @@map("question_tags")
}

// ─── Exams ──────────────────────────────────────────────────────

model Exam {
  id              String      @id @default(uuid())
  tenantId        String      @map("tenant_id")
  title           String
  code            String
  type            ExamType
  status          ExamStatus  @default(DRAFT)
  description     String?
  startTime       DateTime    @map("start_time")
  endTime         DateTime    @map("end_time")
  timezone        String      @default("UTC")
  settings        Json?
  securityPolicy  Json?               @map("security_policy")
  createdById     String      @map("created_by_id")
  publishedAt     DateTime?   @map("published_at")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")
  tenant          Tenant      @relation(fields: [tenantId], references: [id])
  createdBy       User        @relation("ExamCreator", fields: [createdById], references: [id])
  sections        ExamSection[]
  registrations   ExamRegistration[]
  sessions        ExamSession[]
  results         ExamResult[]

  @@unique([tenantId, code])
  @@index([tenantId, status])
  @@index([startTime, endTime])
  @@map("exams")
}

enum ExamType {
  GOVERNMENT
  UNIVERSITY
  RECRUITMENT
  CERTIFICATION
  ONLINE_ASSESSMENT
  CODING
}

enum ExamStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model ExamSection {
  id              String    @id @default(uuid())
  examId          String    @map("exam_id")
  name            String
  description     String?
  orderIndex      Int       @map("order_index")
  durationMinutes Int?      @map("duration_minutes")
  instructions    String?
  negativeMarking Boolean   @default(false) @map("negative_marking")
  createdAt       DateTime  @default(now()) @map("created_at")
  exam            Exam      @relation(fields: [examId], references: [id], onDelete: Cascade)
  questions       ExamQuestion[]

  @@unique([examId, orderIndex])
  @@map("exam_sections")
}

model ExamQuestion {
  id              String    @id @default(uuid())
  examId          String    @map("exam_id")
  sectionId       String    @map("section_id")
  questionId      String    @map("question_id")
  orderIndex      Int       @map("order_index")
  marks           Float?
  negativeMarks   Float?    @map("negative_marks")
  section         ExamSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  question        Question  @relation(fields: [questionId], references: [id])

  @@unique([sectionId, questionId])
  @@index([examId])
  @@map("exam_questions")
}

model ExamRegistration {
  id              String              @id @default(uuid())
  examId          String              @map("exam_id")
  candidateId     String              @map("candidate_id")
  status          RegistrationStatus  @default(REGISTERED)
  admitCardUrl    String?             @map("admit_card_url")
  registeredAt    DateTime            @default(now()) @map("registered_at")
  exam            Exam                @relation(fields: [examId], references: [id])
  candidate       Candidate           @relation(fields: [candidateId], references: [id])
  sessions        ExamSession[]

  @@unique([examId, candidateId])
  @@index([examId, status])
  @@map("exam_registrations")
}

enum RegistrationStatus {
  REGISTERED
  ADMIT_CARD_ISSUED
  CHECKED_IN
  APPEARED
  ABSENT
}

// ─── Exam Engine ────────────────────────────────────────────────

model ExamSession {
  id                  String          @id @default(uuid())
  examId              String          @map("exam_id")
  candidateId         String          @map("candidate_id")
  registrationId      String          @map("registration_id")
  status              SessionStatus   @default(WAITING)
  startedAt           DateTime?       @map("started_at")
  submittedAt         DateTime?       @map("submitted_at")
  timeRemainingSeconds Int?           @map("time_remaining_seconds")
  currentSectionId    String?         @map("current_section_id")
  questionOrder       Json?           @map("question_order")
  riskScore           Float           @default(0) @map("risk_score")
  ipAddress           String?         @map("ip_address")
  deviceFingerprint   String?         @map("device_fingerprint")
  userAgent           String?         @map("user_agent")
  attemptNumber       Int             @default(1) @map("attempt_number")
  createdAt           DateTime        @default(now()) @map("created_at")
  updatedAt           DateTime        @updatedAt @map("updated_at")
  exam                Exam            @relation(fields: [examId], references: [id])
  candidate           Candidate       @relation(fields: [candidateId], references: [id])
  registration        ExamRegistration @relation(fields: [registrationId], references: [id])
  responses           SessionResponse[]
  proctoringEvents    ProctoringEvent[]
  securityViolations  SecurityViolation[]
  result              ExamResult?

  @@index([examId, status])
  @@index([candidateId, examId])
  @@index([examId, status, candidateId])
  @@map("exam_sessions")
}

enum SessionStatus {
  WAITING
  IDENTITY_VERIFICATION
  IN_PROGRESS
  PAUSED
  SUBMITTED
  AUTO_SUBMITTED
  TERMINATED
  EXPIRED
}

model SessionResponse {
  id                  String    @id @default(uuid())
  sessionId           String    @map("session_id")
  questionId          String    @map("question_id")
  answer              Json?
  isCorrect           Boolean?  @map("is_correct")
  marksAwarded        Float?    @map("marks_awarded")
  markedForReview     Boolean   @default(false) @map("marked_for_review")
  timeSpentSeconds    Int       @default(0) @map("time_spent_seconds")
  answeredAt          DateTime? @map("answered_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  session             ExamSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  question            Question  @relation(fields: [questionId], references: [id])

  @@unique([sessionId, questionId])
  @@index([sessionId])
  @@map("session_responses")
}

// ─── Proctoring & Security ──────────────────────────────────────

model ProctoringEvent {
  id              String              @id @default(uuid())
  sessionId       String              @map("session_id")
  eventType       ProctoringEventType @map("event_type")
  confidence      Float?
  severity        ViolationSeverity   @default(LOW)
  metadata        Json?
  snapshotUrl     String?             @map("snapshot_url")
  occurredAt      DateTime            @default(now()) @map("occurred_at")
  session         ExamSession         @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, occurredAt(sort: Desc)])
  @@index([sessionId, severity])
  @@map("proctoring_events")
}

enum ProctoringEventType {
  NO_FACE
  MULTIPLE_FACES
  FACE_MISMATCH
  LOOKING_AWAY
  HEAD_TURNED
  PHONE_DETECTED
  AUDIO_ANOMALY
  TAB_SWITCH
  WINDOW_BLUR
  COPY_ATTEMPT
  PASTE_ATTEMPT
  RIGHT_CLICK
  DEVTOOLS
  PRINT_ATTEMPT
  SCREEN_CAPTURE
  FULLSCREEN_EXIT
  VPN_DETECTED
  VM_DETECTED
}

enum ViolationSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model SecurityViolation {
  id              String              @id @default(uuid())
  sessionId       String              @map("session_id")
  type            String
  severity        ViolationSeverity   @default(MEDIUM)
  details         Json?
  actionTaken     String?             @map("action_taken")
  occurredAt      DateTime            @default(now()) @map("occurred_at")
  session         ExamSession         @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, occurredAt(sort: Desc)])
  @@map("security_violations")
}

// ─── Results ────────────────────────────────────────────────────

model ExamResult {
  id                  String            @id @default(uuid())
  sessionId           String            @unique @map("session_id")
  examId              String            @map("exam_id")
  candidateId         String            @map("candidate_id")
  totalScore          Float             @map("total_score")
  maxScore            Float             @map("max_score")
  percentage          Float
  rank                Int?
  percentile          Float?
  evaluationStatus    EvaluationStatus  @default(PENDING) @map("evaluation_status")
  published           Boolean           @default(false)
  publishedAt         DateTime?         @map("published_at")
  cutoffMet           Boolean?          @map("cutoff_met")
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")
  session             ExamSession       @relation(fields: [sessionId], references: [id])
  exam                Exam              @relation(fields: [examId], references: [id])
  candidate           Candidate         @relation(fields: [candidateId], references: [id])
  sectionResults      SectionResult[]

  @@index([examId, rank])
  @@index([examId, published])
  @@index([candidateId])
  @@map("exam_results")
}

enum EvaluationStatus {
  PENDING
  AUTO_EVALUATED
  MANUAL_REVIEW
  EVALUATED
  PUBLISHED
}

model SectionResult {
  id              String      @id @default(uuid())
  resultId        String      @map("result_id")
  sectionId       String      @map("section_id")
  sectionName     String      @map("section_name")
  score           Float
  maxScore        Float       @map("max_score")
  percentage      Float

  result          ExamResult  @relation(fields: [resultId], references: [id], onDelete: Cascade)

  @@map("section_results")
}

// ─── Coding Submissions ─────────────────────────────────────────

model CodingSubmission {
  id              String    @id @default(uuid())
  sessionId       String    @map("session_id")
  questionId      String    @map("question_id")
  language        String
  sourceCode      String    @map("source_code")
  testResults     Json?     @map("test_results")
  passedTests     Int       @default(0) @map("passed_tests")
  totalTests      Int       @default(0) @map("total_tests")
  executionTimeMs Int?      @map("execution_time_ms")
  memoryUsedKb    Int?      @map("memory_used_kb")
  plagiarismScore Float?    @map("plagiarism_score")
  submittedAt     DateTime  @default(now()) @map("submitted_at")

  @@index([sessionId, questionId])
  @@map("coding_submissions")
}

// ─── Audit ──────────────────────────────────────────────────────

model AuditLog {
  id              String    @id @default(uuid())
  tenantId        String    @map("tenant_id")
  userId          String?   @map("user_id")
  action          String
  resourceType    String    @map("resource_type")
  resourceId      String?   @map("resource_id")
  oldValue        Json?     @map("old_value")
  newValue        Json?     @map("new_value")
  ipAddress       String?   @map("ip_address")
  userAgent       String?   @map("user_agent")
  severity        String    @default("INFO")
  createdAt       DateTime  @default(now()) @map("created_at")
  tenant          Tenant    @relation(fields: [tenantId], references: [id])
  user            User?     @relation(fields: [userId], references: [id])

  @@index([tenantId, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@index([resourceType, resourceId])
  @@map("audit_logs")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  tokenHash String    @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
  @@index([userId])
  @@map("password_reset_tokens")
}
