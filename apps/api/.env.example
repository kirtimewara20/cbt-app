# Copy to apps/api/.env (Prisma and NestJS read this file)
NODE_ENV=development
APP_URL=http://localhost:3002
API_URL=http://localhost:4000
API_PORT=4000

# PostgreSQL — Docker: pnpm docker:up | Without Docker: install PostgreSQL locally (see README)
DATABASE_URL=postgresql://cbt_user:cbt_password@localhost:5432/cbt_platform?schema=public

# Redis optional in dev — leave empty if not installed
REDIS_URL=

JWT_ACCESS_SECRET=dev-access-secret-min-32-characters-long
JWT_REFRESH_SECRET=dev-refresh-secret-min-32-characters-long
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
MFA_ISSUER=CBT Platform
TOTP_WINDOW=1
