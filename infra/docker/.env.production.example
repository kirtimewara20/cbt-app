# Copy to infra/docker/.env.production and fill in real values before deploy.
# Domain example: https://cbt.yourdomain.com

# --- Public URLs (used at web build time AND runtime) ---
APP_URL=https://cbt.yourdomain.com
NEXT_PUBLIC_API_URL=https://cbt.yourdomain.com/api/v1
NEXT_PUBLIC_WS_URL=wss://cbt.yourdomain.com

# Optional extra CORS origins (comma-separated)
# CORS_ORIGINS=https://www.yourdomain.com

# --- Database ---
POSTGRES_USER=cbt_user
POSTGRES_PASSWORD=change-me-strong-db-password
POSTGRES_DB=cbt_platform

# --- JWT (generate: openssl rand -base64 48) ---
JWT_ACCESS_SECRET=change-me-access-secret-min-32-characters-long
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-characters-long
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# --- MFA ---
MFA_ISSUER=CBT Platform
TOTP_WINDOW=1

# --- Email (optional — password reset) ---
# SMTP_HOST=smtp.yourprovider.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@yourdomain.com

# --- Nginx ---
HTTP_PORT=80
