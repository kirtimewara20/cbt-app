# Application
# Note: Prisma and the API load apps/api/.env — copy apps/api/.env.example there first.
NODE_ENV=development
APP_NAME=CBT Platform
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
API_PORT=4000

# Database
DATABASE_URL=postgresql://cbt_user:cbt_password@localhost:5432/cbt_platform?schema=public
DATABASE_READ_REPLICA_URL=postgresql://cbt_user:cbt_password@localhost:5433/cbt_platform?schema=public

# Redis
REDIS_URL=redis://localhost:6379
REDIS_CLUSTER_NODES=localhost:6379

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Encryption
AES_ENCRYPTION_KEY=change-me-32-byte-aes-key-here!!
AES_ENCRYPTION_IV=change-me-16byte

# MFA
MFA_ISSUER=CBT Platform
TOTP_WINDOW=1

# AWS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=cbt-platform-uploads
AWS_SQS_PROCTORING_QUEUE=cbt-proctoring-events

# Cloudflare
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=

# AI / LLM
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# AI Proctoring
AI_PROCTORING_ENABLED=true
AI_PROCTORING_API_URL=http://localhost:5000
FACE_MATCH_THRESHOLD=0.85
RISK_SCORE_THRESHOLD=70

# Code Execution
CODE_SANDBOX_URL=http://localhost:5001
CODE_EXECUTION_TIMEOUT_MS=10000

# Email
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@cbt-platform.com

# Monitoring
SENTRY_DSN=
DATADOG_API_KEY=

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# Multi-tenant
DEFAULT_TENANT_ID=default
TENANT_DB_ISOLATION=schema
